---
import Header from "../components/Header.astro";
import Footerv2 from "../components/Footerv2.astro";
import ContactBar from "../components/ContactBar.astro";
import CallButton from "../components/CallButton.astro";
import ContactForm from "../components/ContactForm.astro";
import MetaCAPI from "../components/MetaCAPI.astro";

// Base layout for all pages
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  keywords?: string;
  image?: string;
  isHome?: boolean;
}

const {
  title,
  description,
  keywords,
  canonical = Astro.request.url,
  image = "/images/logo.png",
  isHome = false,
} = Astro.props;

const canonicalURL = canonical;

const homepageStructuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Corporation",
      "@id": "https://soreyapi.com/#organization",
      name: "Sore Yapı",
      legalName:
        "ERDİR GAYRİMENKUL YATIRIM İNŞAAT VE YÖNETİM DANIŞMANLIĞI TURİZM SANAYİ VE TİCARET LİMİTED ŞİRKETİ",
      url: "https://soreyapi.com",
      logo: {
        "@type": "ImageObject",
        url: "https://soreyapi.com/images/logo-dark-2.png",
        width: 250,
        height: 60,
      },
      description:
        "Sore Yapı, Kuşadası ve Aydın bölgesinde faaliyet gösteren, gayrimenkul geliştirme, inşaat ve yatırım danışmanlığı alanlarında uzman bir şirkettir.",
      slogan: "Her Detayında Kalite, Her Zaman Güven",
      email: "info@soreyapi.com",
      telephone: "+902569110331",
      address: {
        "@type": "PostalAddress",
        streetAddress:
          "TÜRKMEN MAH. KAYMAKAN SK. KOZ APT NO: 1 İÇ KAPI NO: 101",
        addressLocality: "Kuşadası",
