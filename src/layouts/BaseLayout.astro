    },
    {
      "@type": "WebSite",
      "@id": "https://soreyapi.com/#website",
      url: "https://soreyapi.com",
      name: "Sore Yapı",
      description:
        "Sore Yapı - Her Detayında Kalite, Her Zaman Güven. İnşaat ve gayrimenkul sektöründe güvenilir çözümler.",
      publisher: {
        "@id": "https://soreyapi.com/#organization",
      },
      inLanguage: "tr-TR",
      potentialAction: {
        "@type": "SearchAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate:
            "https://soreyapi.com/projeler?search={search_term_string}",
        },
        "query-input": "required name=search_term_string",
      },
    },
    {
      "@type": "WebPage",
      "@id": "https://soreyapi.com/#webpage",
      url: "https://soreyapi.com",
      name: "Sore Yapı",
      description:
        "Sore Yapı'nın resmi web sitesidir. İnşaat ve gayrimenkul sektöründeki uzmanlığımız, projelerimiz ve hizmetlerimiz hakkında bilgi edinin.",
      isPartOf: {
        "@id": "https://soreyapi.com/#website",
      },
      about: {
        "@id": "https://soreyapi.com/#organization",
      },
      inLanguage: "tr-TR",
      breadcrumb: {
        "@id": "https://soreyapi.com/#breadcrumb",
      },
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://soreyapi.com/#breadcrumb",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Ana Sayfa",
          item: "https://soreyapi.com",
        },
      ],
    },
    {
      "@type": "Service",
      "@id": "https://soreyapi.com/#services",
      provider: {
        "@id": "https://soreyapi.com/#organization",
      },
      serviceType: "İnşaat ve Gayrimenkul Hizmetleri",
      areaServed: {
        "@type": "Country",
        name: "Türkiye",
      },
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Sore Yapı Hizmetleri",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Proje Geliştirme",
              description:
                "Modern yaşam alanları ve yüksek getiri potansiyeli taşıyan projeler; bölge analizi, mimari tasarım ve ruhsat süreçlerinin uçtan uca yönetimi.",
              provider: {
                "@id": "https://soreyapi.com/#organization",
              },
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Satış ve Pazarlama",
              description:
                "Şeffaf, güvenilir ve veriye dayalı satış süreçleri; doğru bilgilendirme ile yatırım ve yaşam alanı eşleştirmesi.",
              provider: {
                "@id": "https://soreyapi.com/#organization",
              },
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Yatırım Danışmanlığı",
              description:
                "Kapsamlı analizler ve stratejik yönlendirmelerle sürdürülebilir, uzun vadeli kazanç odaklı yatırım planları.",
              provider: {
                "@id": "https://soreyapi.com/#organization",
              },
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Finansal Danışmanlık",
              description:
                "Kişiye özel ödeme planları, kredi yönlendirmeleri ve mali analizlerle erişilebilir finansal çözümler.",
              provider: {
                "@id": "https://soreyapi.com/#organization",
              },
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
