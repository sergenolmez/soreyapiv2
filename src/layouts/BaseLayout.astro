        { "@type": "Country", name: "Türkiye" },
      ],
      sameAs: [
        "https://maps.app.goo.gl/c1pTdoQyPhGZePXm6",
        "https://instagram.com/soreyapi",
      ],
      contactPoint: {
        "@type": "ContactPoint",
        contactType: "customer service",
        telephone: "+902569110331",
        email: "info@soreyapi.com",
        availableLanguage: ["Turkish"],
        areaServed: "TR",
      },
      foundingDate: "2010",
      numberOfEmployees: {
        "@type": "QuantitativeValue",
        value: 25,
      },
      knowsAbout: [
        "Proje Geliştirme",
        "Gayrimenkul Yatırım",
        "İnşaat",
        "Satış ve Pazarlama",
        "Finansal Danışmanlık",
        "Tapu ve Hukuki Süreç",
        "Satış Sonrası Hizmetler",
