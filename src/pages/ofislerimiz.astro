---
import BaseLayout from "../layouts/BaseLayout.astro";

const offices = [
    {
        name: "Folkart Lıfe Ofis",
        address: "364/11 Sok.No:1 D:3D Kazımdirik Mah. - Bornova - İzmir",
        phone: "+90 (256) 911 03 31",
        email: "info@soreyapi.com",
        mapSrc: "https://www.google.com/maps/embed?pb=!1m13!1m8!1m3!1d24998.46005011951!2d27.200995!3d38.445915!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zMzjCsDI2JzQ1LjMiTiAyN8KwMTInMDMuNiJF!5e0!3m2!1str!2sus!4v1766391002973!5m2!1str!2sus",
    },
    {
        name: "Forum Ofis",
        address: "372/14 Sokak. No:11 Kazımdirik Mah. - Bornova - İzmir",
        phone: "+90 (256) 911 03 31",
        email: "info@soreyapi.com",
        mapSrc: "https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d3124.72008323608!2d27.209222977147114!3d38.44793407309713!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zMzjCsDI2JzUyLjYiTiAyN8KwMTInNDIuNSJF!5e0!3m2!1str!2str!4v1766405861838!5m2!1str!2str", // Placeholder map
    },
    {
        name: "Girne Bulvarı Ofis",
        address: "Girne Bulvarı No:49 D:1   Bostanlı Mah. - Karşıyaka - İzmir",
        phone: "+90 (256) 911 03 31",
        email: "info@soreyapi.com",
        mapSrc: "https://www.google.com/maps/embed?pb=!1m13!1m8!1m3!1d1562.1957942906033!2d27.106557!3d38.45552!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zMzjCsDI3JzE5LjkiTiAyN8KwMDYnMjMuNiJF!5e0!3m2!1str!2sus!4v1766391332033!5m2!1str!2sus", // Placeholder map
    },
];
---

<BaseLayout
    title="Ofislerimiz - Sore Yapı"
    description="Sore Yapı ofis ve şubeleri. Size en yakın ofisimizi ziyaret edin."
>
    <div class="page-content">
        <!-- INNER PAGE BANNER -->
        <div
            class="wt-bnr-inr overlay-wraper bg-parallax bg-top-center"
            data-stellar-background-ratio="0.5"
            style="background-image:url(/images/banner/3.jpg);"
        >
            <div class="overlay-main bg-black opacity-07"></div>
            <div class="container">
                <div class="wt-bnr-inr-entry">
                    <div class="banner-title-outer">
                        <div class="banner-title-name">
                            <h2
                                class="text-white text-uppercase letter-spacing-5 font-18 font-weight-300 m-0"
                            >
                                Sore Yapı <br /> Ofislerimiz
                            </h2>
                        </div>
                    </div>
                    <!-- BREADCRUMB ROW -->
                    <div class="p-tb20">
                        <div>
                            <ul class="wt-breadcrumb breadcrumb-style-2">
                                <li><a href="/">Anasayfa</a></li>
                                <li>Ofislerimiz</li>
                            </ul>
                        </div>
                    </div>
                    <!-- BREADCRUMB ROW END -->
                </div>
            </div>
        </div>
        <!-- INNER PAGE BANNER END -->

        <!-- OFFICE CARDS SECTION -->
        <div class="section-full p-tb80 bg-gray">
            <div class="container">
                <!-- <div class="section-head text-left text-black">
                    <h2 class="text-uppercase font-36">Şube ve Ofislerimiz</h2>
                    <div class="wt-separator-outer">
                        <div class="wt-separator bg-black"></div>
                    </div>
                </div> -->

                <div class="row">
                    {
                        offices.map((office) => (
                            <div class="col-lg-12 m-b40">
                                <div class="wt-box bg-white p-a20 border-1 border-gray">
                                    <div class="row">
                                        <div class="col-lg-5 col-md-12">
                                            <h4 class="wt-tilte text-uppercase m-b20 font-weight-700">
                                                {office.name}
                                            </h4>
                                            <div class="wt-icon-box-wraper left p-b20">
                                                <div class="icon-sm">
                                                    <span class="icon-cell text-primary">
                                                        <i class="fa fa-map-marker" />
                                                    </span>
                                                </div>
                                                <div class="icon-content">
                                                    <h5 class="wt-tilte text-uppercase m-b0">
                                                        Adres
                                                    </h5>
                                                    <p>{office.address}</p>
                                                </div>
                                            </div>
                                            <div class="wt-icon-box-wraper left p-b20">
                                                <div class="icon-sm">
                                                    <span class="icon-cell text-primary">
                                                        <i class="fa fa-phone" />
                                                    </span>
                                                </div>
                                                <div class="icon-content">
                                                    <h5 class="wt-tilte text-uppercase m-b0">
                                                        Telefon
                                                    </h5>
                                                    <p>{office.phone}</p>
                                                </div>
                                            </div>
                                            <div class="wt-icon-box-wraper left p-b20">
                                                <div class="icon-sm">
                                                    <span class="icon-cell text-primary">
                                                        <i class="fa fa-envelope" />
                                                    </span>
                                                </div>
                                                <div class="icon-content">
                                                    <h5 class="wt-tilte text-uppercase m-b0">
                                                        E-Posta
                                                    </h5>
                                                    <p>{office.email}</p>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-lg-7 col-md-12">
                                            <div class="gmap-outline h-100">
                                                <div class="google-map h-100">
                                                    <iframe
                                                        src={office.mapSrc}
                                                        width="100%"
                                                        height="300"
                                                        style="border:0; height: 100%; min-height: 300px;"
                                                        allowfullscreen=""
                                                        loading="lazy"
                                                        referrerpolicy="no-referrer-when-downgrade"
                                                    />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</BaseLayout>
