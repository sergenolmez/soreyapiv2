---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Kuşadası Egel Park Sitesi - Sore Yapı "
  description="Kuşadası Ege Mahallesi’nde konumlanan Egel Park, yüksek tavanlı yaşam alanları, güçlü teknik altyapısı ve seçkin sosyal imkânlarıyla öne çıkar. 3+1, 2+1 ve 4+1 dubleks seçenekleri, kaliteli iç mimari ve güvenlikli site yaşamı ile dört mevsim konfor sunar."
>
  <!-- CONTENT START -->
  <div class="page-content">
    <!-- INNER PAGE BANNER -->
    <div
      class="wt-bnr-inr overlay-wraper bg-parallax bg-top-center"
      data-stellar-background-ratio="0.5"
      style="background-image:url(/images/banner/egelpark-banner.jpg)"
    >
      <div class="overlay-main bg-black opacity-07"></div>
      <div class="container">
        <div class="wt-bnr-inr-entry">
          <div class="banner-title-outer">
            <div class="banner-title-name">
              <h2
                class="text-white text-uppercase letter-spacing-5 font-18 font-weight-300 m-0"
              >
                Egel Park Sitesi <br />Ege Mahallesi'nde Modern Yaşam
              </h2>
            </div>
          </div>
          <!-- BREADCRUMB ROW -->
          <div class="p-tb20">
            <div>
              <ul class="wt-breadcrumb breadcrumb-style-2">
                <li>
                  <a href="javascript:void(0);">Anasayfa</a>
                </li>
                <li>Egel Park Sitesi</li>
              </ul>
            </div>
          </div>
          <!-- BREADCRUMB ROW END -->
        </div>
      </div>
    </div>
    <!-- INNER PAGE BANNER END -->
    <!-- PROJECT DETAIL SECTION START -->
    <div class="section-full p-t80 p-b50">
      <div class="container">
        <div class="project-detail-outer bg-center m-b30">
          <div class="row">
            <div
              class="col-lg-12 col-md-12 project-detail-containt square_shape3 text-center"
            >
              <div class="p-lr20 p-tb20 project-detail-containt-info bg-black">
                <div class="bg-white p-lr30 p-tb30 text-black">
                  <h2 class="m-t0">
                    <span class="font-34 text-uppercase"
                      >EGEL PARK - KUŞADASI</span
                    >
                  </h2>
                  <p>
                    <strong
                      >Kuşadası Ege Mahallesi’nde yüksek tavanlı, modern ve
                      güvenli yaşam.</strong
                    >
                  </p>
                  <p>
                    Egel Park, yüksek tavanlı yaşam alanları, güçlü teknik
                    altyapısı ve seçkin sosyal imkânlarıyla öne çıkar. 3+1, 2+1
                    ve 4+1 dubleks seçenekleriyle, Anka seramikten Belenco
                    tezgâha, Variodor iç kapılardan AGT laminant parkeye kadar
                    kaliteli malzeme standardı sunar. Yerden ısıtma ve doğalgaz
                    altyapısı ile dört mevsim konfor sağlar. Dış cephede
                    Fıratpen ısıcam doğrama, güvenli giriş sistemi ve peyzajlı
                    ortak alanlar site yaşamını tamamlar.
                  </p>
                  <div class="product-block">
                    <div class="row">
                      <div class="col-md-6 col-sm-6 m-b20">
                        <h5 class="text-uppercase">Başlangç Tarihi:</h5>
                        <p><b>2020</b></p>
                      </div>
                      <div class="col-md-6 col-sm-6 m-b20">
                        <h5 class="text-uppercase">Teslim Tarihi:</h5>
                        <p><b>Hemen Teslim</b></p>
                      </div>
                      <div class="col-md-6 col-sm-6 m-b20">
                        <h5 class="text-uppercase">Durum:</h5>
                        <p>
                          <b>Tamamlandı</b>
                        </p>
                      </div>
                      <div class="col-md-6 col-sm-6 m-b20">
                        <h5 class="text-uppercase">Faaliyet:</h5>
                        <p><b>2024</b></p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- PROJECT DETAIL SECTION END -->
