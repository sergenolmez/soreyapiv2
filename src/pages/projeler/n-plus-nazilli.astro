---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="N Plus Nazilli - Sore Yapı "
  description="Nazilli'de yer alan N Plus Nazilli projemizi keşfedin. Modern yaşam alanları, sosyal olanaklar ve prestijli konut seçenekleri hakkında bilgi edinin."
>
  <!-- CONTENT START -->
  <div class="page-content">
    <!-- INNER PAGE BANNER -->
    <div
      class="wt-bnr-inr overlay-wraper bg-parallax bg-top-center"
      data-stellar-background-ratio="0.5"
      style="background-image:url(/images/banner/n-plus-nazilli-banner.png)"
    >
      <div class="overlay-main bg-black opacity-07"></div>
      <div class="container">
        <div class="wt-bnr-inr-entry">
          <div class="banner-title-outer">
            <div class="banner-title-name">
              <h2
                class="text-white text-uppercase letter-spacing-5 font-18 font-weight-300 m-0"
              >
                N Plus <br />Nazilli / Aydın
              </h2>
            </div>
          </div>
          <!-- BREADCRUMB ROW -->
          <div class="p-tb20">
            <div>
              <ul class="wt-breadcrumb breadcrumb-style-2">
                <li>
                  <a href="javascript:void(0);">Anasayfa</a>
                </li>
                <li>N Plus Nazilli</li>
              </ul>
            </div>
          </div>
          <!-- BREADCRUMB ROW END -->
        </div>
      </div>
    </div>
    <!-- INNER PAGE BANNER END -->
    <!-- PROJECT DETAIL SECTION START -->
    <div class="section-full p-t80 p-b50">
      <div class="container">
        <div class="project-detail-outer bg-center m-b30">
          <div class="row">
            <div
              class="col-lg-12 col-md-12 project-detail-containt square_shape3 text-center"
            >
              <div class="p-lr20 p-tb20 project-detail-containt-info bg-black">
                <div class="bg-white p-lr30 p-tb30 text-black">
                  <h2 class="m-t0">
                    <span class="font-34 text-uppercase"
                      >N Plus Nazilli - Aydın</span
                    >
                  </h2>
                  <p>
                    Nazilli’nin en prestijli projesinde satışlar başladı! Modern
                    mimarisi, merkezi konumu ve yüksek yatırım potansiyeliyle N
                    Plus Nazilli, kazançlı bir geleceğe adım atmak isteyenler
                    için benzersiz bir fırsat sunuyor!
                  </p>
