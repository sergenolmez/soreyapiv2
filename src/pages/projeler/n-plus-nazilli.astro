      <!-- CTA SECTION START -->
      <div class="section-full clearfix p-b80 square_shape1 square_shape3">
        <div class="container">
          <div
            class="row d-flex justify-content-center bg-darks p-a40 radius-m"
          >
            <div class="col-lg-8 col-md-10 text-center">
              <div class="cta-content">
                <h2 class="text-white text-uppercase m-b20">
                  N Plus Nazilli'de Yerinizi Ayırtın
                </h2>
                <p class="text-white font-14 m-b30 opacity-08">
                  Projemizde, 2 adet örnek daire seçenekleri arasından tercih
                  yapın.
                </p>
                <p class="text-white font-18 m-b30 bold text-uppercase">
                  Detaylı bilgi ve örnek daire ziyareti için randevu alın.
                </p>
                <div class="cta-buttons">
