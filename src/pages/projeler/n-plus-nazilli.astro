                    <div class="row">
                      <div class="col-md-6 col-sm-6 m-b20">
                        <h5 class="text-uppercase">Başlangıç Tarihi:</h5>
                        <p>
                          <b>Ekim 15, 2024</b>
                        </p>
                      </div>
                      <div class="col-md-6 col-sm-6 m-b20">
                        <h5 class="text-uppercase">Teslim Tarihi:</h5>
                        <p>
                          <b>Hemen Teslim</b>
                        </p>
                      </div>
                      <div class="col-md-6 col-sm-6 m-b20">
                        <h5 class="text-uppercase">Durum:</h5>
                        <p>
                          <b>Tamamlandı</b>
                        </p>
                      </div>
                      <div class="col-md-6 col-sm-6 m-b20">
                        <h5 class="text-uppercase">Faaliyet:</h5>
                        <p>
                          <b>Aralık 2026</b>
                        </p>
                      </div>
                    </div>
                  </div> -->
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- PROJECT DETAIL SECTION END -->

      <!-- PROMO BANNER SECTION START -->
      <div class="section-full p-tb50 bg-black square_shape1">
        <div class="container">
          <div class="row">
            <div class="col-md-12 text-center text-white">
              <h2 class="m-b10 font-40 font-weight-300 text-uppercase">
                <span class="text-white">36 Aya Kadar Vade</span>
              </h2>
              <h2
                class="m-b0 font-30 font-weight-800 text-uppercase text-white"
              >
                800.000 TL'den Başlayan Peşinatla
              </h2>
              <p class="font-24 m-t20 m-b0 letter-spacing-2 font-weight-300">
                EV SAHİBİ OLMA FIRSATINI KAÇIRMAYIN
              </p>
            </div>
          </div>
        </div>
        <div class="cta-buttons p-t60 text-center">
          <button
            class="m-b15 site-button m-r15 text-uppercase letter-spacing-2"
            type="button"
            data-bs-toggle="modal"
            data-bs-target="#contact-form-modal">Bize Ulaşın</button
          >
          <a href="tel:+905551234567">
            <button
              class="m-b15 site-button-secondry text-uppercase letter-spacing-2"
              type="button">Hemen Arayın</button
            >
          </a>
        </div>
      </div>
