---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Kuşadası AtaPark 1. Etap - Sore Yapı "
  description="Kuşadası’nın nitelikli konut aksında konumlanan AtaPark 1. Etap, kat mülkiyetli tapu ile hemen devir avantajı ve sınırlı stoklu, güvenli site yaşamı sunar. Kapalı otopark, modern altyapı ve kaliteli malzeme ile taşınmaya hazır konutlar."
>
  <!-- CONTENT START -->
  <div class="page-content">
    <!-- INNER PAGE BANNER -->
    <div
      class="wt-bnr-inr overlay-wraper bg-parallax bg-top-center"
      data-stellar-background-ratio="0.5"
      style="background-image:url(/images/banner/atapark-banner.jpg)"
    >
      <div class="overlay-main bg-black opacity-07"></div>
      <div class="container">
        <div class="wt-bnr-inr-entry">
          <div class="banner-title-outer">
            <div class="banner-title-name">
              <h2
                class="text-white text-uppercase letter-spacing-5 font-18 font-weight-300 m-0"
              >
                AtaPark 1. Etap <br />Kuşadası’nda Hemen Taşın, Hemen Tapu
              </h2>
            </div>
          </div>
          <!-- BREADCRUMB ROW -->
          <div class="p-tb20">
            <div>
              <ul class="wt-breadcrumb breadcrumb-style-2">
                <li>
                  <a href="javascript:void(0);">Anasayfa</a>
                </li>
                <li>AtaPark 1. Etap</li>
              </ul>
            </div>
          </div>
          <!-- BREADCRUMB ROW END -->
        </div>
      </div>
    </div>
    <!-- INNER PAGE BANNER END -->
    <!-- PROJECT DETAIL SECTION START -->
    <div class="section-full p-t80 p-b50">
      <div class="container">
        <div class="project-detail-outer bg-center m-b30">
          <div class="row">
            <div
              class="col-lg-12 col-md-12 project-detail-containt square_shape3 text-center"
            >
              <div class="p-lr20 p-tb20 project-detail-containt-info bg-black">
                <div class="bg-white p-lr30 p-tb30 text-black">
                  <h2 class="m-t0">
                    <span class="font-34 text-uppercase"
                      >ATAPARK 1. ETAP - KUŞADASI</span
                    >
                  </h2>
                  <p>
                    <strong
                      >Kuşadası’nın nitelikli konut aksında, hemen taşın, hemen
                      tapu avantajı.</strong
                    >
                  </p>
                  <p>
                    AtaPark 1. Etap, kat mülkiyetli tapu ile hemen devir ve
                    taşınma imkanı sunar. Sınırlı üretim ve düzenli site ölçeği
                    sayesinde sakin, kontrollü ve güvenli bir yaşam atmosferi
                    sağlar. Kapalı otopark, modern altyapı ve kaliteli malzeme
                    tercihleriyle uzun ömürlü ve konforlu bir yaşam sunar.
                    Proje, “beklemeden yerleşmek” isteyenler için pratik bir
                    seçenektir.
                  </p>
                  <div class="product-block">
                    <div class="row">
                      <div class="col-md-6 col-sm-6 m-b20">
                        <h5 class="text-uppercase">Stokta:</h5>
                        <p><b>1+1 Daire ve 2+1 Dubleks (Son Stoklar)</b></p>
                      </div>
                      <div class="col-md-6 col-sm-6 m-b20">
                        <h5 class="text-uppercase">Toplam Daire:</h5>
                        <p><b>22 (diğer tipler satılmıştır)</b></p>
                      </div>
                      <div class="col-md-6 col-sm-6 m-b20">
                        <h5 class="text-uppercase">Tapu:</h5>
                        <p><b>Kat Mülkiyeti – Hemen devir hazır</b></p>
                      </div>
                      <div class="col-md-6 col-sm-6 m-b20">
                        <h5 class="text-uppercase">Otopark:</h5>
                        <p><b>Kapalı otopark mevcut</b></p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- PROJECT DETAIL SECTION END -->
