<style>
  .site-footer {
    background: #161616;
    padding: 4rem 0 2.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 50px 50px 0 0;
  }
  .site-footer .footer-brand {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    text-align: center;
  }
  .site-footer .footer-brand:hover {
    transition: transform 0.3s ease;
    transform: scale(1.05);
  }
  .site-footer .footer-social {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .site-footer .footer-social .circle {
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    color: #e8eaf1;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.03);
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
  }
  .site-footer .footer-social .circle i {
    font-size: 18px;
  }

  .site-footer .footer-nav {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
    margin: 0.75rem 0 1.25rem;
  }
  .site-footer .footer-nav a {
    color: #e8eaf1;
    opacity: 0.9;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .site-footer .footer-nav a:hover {
    opacity: 1;
  }

  .site-footer .footer-cta {
    display: flex;
    justify-content: center;
    margin: 0.5rem 0 1.25rem;
  }
  .site-footer .footer-call {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 1.2rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.06);
    color: #e8eaf1;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .site-footer .footer-emails {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
    margin: 0.75rem 0 1.25rem;
    font-size: 1rem;
  }
  .site-footer .footer-emails a {
    color: #b9bfcc;
  }

  .site-footer .footer-legal {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    color: #9aa3b2;
    font-size: 0.8rem;
  }

  .site-footer .footer-copy {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    color: #9aa3b2;
    font-size: 0.8rem;
    margin-top: 1rem;
  }

  .site-footer .footer-legal .copy {
    justify-content: center;
  }
  .site-footer .footer-legal a {
    color: #9aa3b2;
  }
  .site-footer .footer-legal .spacer {
    flex: 1 1 auto;
  }
  .site-footer .brand {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    justify-content: center;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: #9aa3b2;
  }
  .site-footer .brand a img {
    filter: brightness(0) invert(1);
    vertical-align: baseline;
  }
  @media (max-width: 640px) {
    .site-footer {
      padding: 3rem 0 2rem;
    }
    .site-footer .footer-nav {
      gap: 1rem;
    }
    .site-footer .footer-emails {
      gap: 1rem;
    }
    .site-footer .footer-legal {
      justify-content: center;
    }
    .site-footer .footer-legal .spacer {
      display: none;
    }
  }
</style>
